From 9418978927e27d25955ddd1c8913048bc5921187 Mon Sep 17 00:00:00 2001
From: adi1090x <adi1090x@gmail.com>
Date: Mon, 13 Jul 2026 13:57:26 +0530
Subject: [PATCH] archcraft-theming-patch

---
 util/grub.d/10_linux.in         | 6 +++---
 util/grub.d/30_os-prober.in     | 6 +++---
 util/grub.d/30_uefi-firmware.in | 2 +-
 util/grub.d/40_custom.in        | 8 ++++++++
 4 files changed, 15 insertions(+), 7 deletions(-)

diff --git a/util/grub.d/10_linux.in b/util/grub.d/10_linux.in
index 07649cd..034f488 100644
--- a/util/grub.d/10_linux.in
+++ b/util/grub.d/10_linux.in
@@ -94,9 +94,9 @@ linux_entry ()
   if [ x$type != xsimple ] ; then
       case $type in
 	  recovery)
-	      title="$(gettext_printf "%s, with Linux %s (recovery mode)" "${os}" "${version}")" ;;
+	      title="$(gettext_printf "%s, with Kernel: %s (recovery mode)" "${os}" "${version}")" ;;
 	  *)
-	      title="$(gettext_printf "%s, with Linux %s" "${os}" "${version}")" ;;
+	      title="$(gettext_printf "%s, with Kernel: %s" "${os}" "${version}")" ;;
       esac
       if [ x"$title" = x"$GRUB_ACTUAL_DEFAULT" ] || [ x"Previous Linux versions>$title" = x"$GRUB_ACTUAL_DEFAULT" ]; then
 	  replacement_title="$(echo "Advanced options for ${OS}" | sed 's,>,>>,g')>$(echo "$title" | sed 's,>,>>,g')"
@@ -293,7 +293,7 @@ for linux in ${reverse_sorted_list}; do
 	boot_device_id="$(grub_get_device_id "${GRUB_DEVICE}")"
     fi
     # TRANSLATORS: %s is replaced with an OS name
-    echo "submenu '$(gettext_printf "Advanced options for %s" "${OS}" | grub_quote)' \$menuentry_id_option 'gnulinux-advanced-$boot_device_id' {"
+    echo "submenu '$(gettext_printf "Advanced options for %s" "${OS}" | grub_quote)' --class recovery \$menuentry_id_option 'gnulinux-advanced-$boot_device_id' {"
     is_top_level=false
   fi
 
diff --git a/util/grub.d/30_os-prober.in b/util/grub.d/30_os-prober.in
index 5d8d752..8e488cd 100644
--- a/util/grub.d/30_os-prober.in
+++ b/util/grub.d/30_os-prober.in
@@ -164,7 +164,7 @@ for OS in ${OSPROBED} ; do
       cat << EOF
 # This menu entry is supported only on PC BIOS platforms.
 if [ "\$grub_platform" = "pc" ]; then
-menuentry '$(echo "${LONGNAME} $onstr" | grub_quote)' $CLASS --class os \$menuentry_id_option 'osprober-chain-$(grub_get_device_id "${DEVICE}")' {
+menuentry '$(echo "${LONGNAME} $onstr" | grub_quote)' $CLASS --class windows --class os \$menuentry_id_option 'osprober-chain-$(grub_get_device_id "${DEVICE}")' {
 EOF
       save_default_entry | grub_add_tab
       prepare_grub_to_access_device ${DEVICE} | grub_add_tab
@@ -199,7 +199,7 @@ EOF
       cat << EOF
 # This menu entry is supported only on EFI platforms.
 if [ "\$grub_platform" = "efi" ]; then
-menuentry '$(echo "${LONGNAME} $onstr" | grub_quote)' $CLASS --class os \$menuentry_id_option 'osprober-efi-$(grub_get_device_id "${DEVICE}")' {
+menuentry '$(echo "${LONGNAME} $onstr" | grub_quote)' $CLASS --class windows --class os \$menuentry_id_option 'osprober-efi-$(grub_get_device_id "${DEVICE}")' {
 EOF
       save_default_entry | sed -e "s/^/\t/"
       prepare_grub_to_access_device ${DEVICE} | sed -e "s/^/\t/"
@@ -279,7 +279,7 @@ EOF
         cat << EOF
 }
 EOF
-	    echo "submenu '$(gettext_printf "Advanced options for %s" "${OS} $onstr" | grub_quote)' \$menuentry_id_option 'osprober-gnulinux-advanced-$boot_device_id' {"
+	    echo "submenu '$(gettext_printf "Advanced options for %s" "${OS} $onstr" | grub_quote)' --class recovery \$menuentry_id_option 'osprober-gnulinux-advanced-$boot_device_id' {"
 	    is_top_level=false
 	fi
 	title="${LLABEL} $onstr"
diff --git a/util/grub.d/30_uefi-firmware.in b/util/grub.d/30_uefi-firmware.in
index 1c2365d..461ad17 100644
--- a/util/grub.d/30_uefi-firmware.in
+++ b/util/grub.d/30_uefi-firmware.in
@@ -34,7 +34,7 @@ cat << EOF
 if [ "\$grub_platform" = "efi" ]; then
 	fwsetup --is-supported
 	if [ "\$?" = 0 ]; then
-		menuentry '$LABEL' \$menuentry_id_option 'uefi-firmware' {
+		menuentry '$LABEL' --class efi \$menuentry_id_option 'uefi-firmware' {
 			fwsetup
 		}
 	fi
diff --git a/util/grub.d/40_custom.in b/util/grub.d/40_custom.in
index 48068de..fb45e58 100644
--- a/util/grub.d/40_custom.in
+++ b/util/grub.d/40_custom.in
@@ -3,3 +3,11 @@ exec tail -n +3 $0
 # This file provides an easy way to add custom menu entries.  Simply type the
 # menu entries you want to add after this comment.  Be careful not to change
 # the 'exec tail' line above.
+
+menuentry 'Reboot Computer' --class restart {
+    reboot
+}
+
+menuentry 'Shutdown Computer' --class shutdown {
+    halt
+}
-- 
2.55.0

